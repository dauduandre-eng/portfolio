# Copy this file to .env and fill in real values.
# .env itself is gitignored — never commit real secrets.

# Generate one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# True locally. Must be False in any environment reachable by the public.
DEBUG=True

# Comma-separated. Django rejects requests whose Host header isn't listed here.
ALLOWED_HOSTS=localhost,127.0.0.1

# Matches the docker-compose Postgres service below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio

# Contact form email, sent via Resend's HTTP API (not SMTP - Render's
# free tier blocks outbound SMTP ports 25/465/587 entirely, confirmed
# directly against this deployment, so Gmail/SMTP never actually worked
# in production regardless of credentials).
#
# Leave RESEND_API_KEY blank locally and submissions just get logged to
# your terminal instead of sent - no real account needed for local dev.
#
# To send real emails: sign up free at https://resend.com, create an API
# key. You can start sending from "onboarding@resend.dev" immediately
# with zero setup; verifying your own domain later lets you send from
# your own address instead.
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=onboarding@resend.dev
CONTACT_RECIPIENT_EMAIL=your-real-address@example.com

# AI chat widget. Leave this blank and the widget simply doesn't appear
# anywhere on the site - no error, no broken-looking UI, it just isn't
# rendered. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5-20251001


