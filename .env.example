# Copy this file to .env and fill in real values.
# .env itself is gitignored — never commit real secrets.

# Generate one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# True locally. Must be False in any environment reachable by the public.
DEBUG=True

# Comma-separated. Django rejects requests whose Host header isn't listed here.
ALLOWED_HOSTS=localhost,127.0.0.1

# Matches the docker-compose Postgres service below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio

# Contact form email. Leave these blank locally — DEBUG=True uses the
# console backend, which just prints emails to your terminal instead of
# sending them. Required once DEBUG=False (production).
#
# Easiest free option to start with: a Gmail "App Password" (not your
# regular password) - https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-address@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-address@gmail.com
CONTACT_RECIPIENT_EMAIL=your-address@gmail.com

# AI chat widget. Leave this blank and the widget simply doesn't appear
# anywhere on the site - no error, no broken-looking UI, it just isn't
# rendered. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5-20251001


